//  MODALES
// ════════════════════════════════════════════════════════
function openAddModal(){document.getElementById('modal-add').style.display='flex';}
function openModalPA(){
  document.getElementById('pa-fecha').value=today();
  document.getElementById('pa-hora').value=nowTime();
  document.getElementById('modal-pa').style.display='flex';
}
function openModalSueno(){
  document.getElementById('su-fecha').value=today();
  document.getElementById('modal-sueno').style.display='flex';
}
function closeModal(id){document.getElementById(id).style.display='none';}
function closeModalIfBg(e,id){if(e.target===document.getElementById(id))closeModal(id);}

// ════════════════════════════════════════════════════════
//  CRUD
// ════════════════════════════════════════════════════════
function addPatient(){
  const nombre=document.getElementById('np-nombre').value.trim();
  if(!nombre){alert('El nombre es obligatorio.');return;}
  const colors=['#c084fc','#74c0fc','#34d399','#ffa94d','#ff6b6b','#fde68a','#f472b6','#38bdf8','#a78bfa'];
  const p={
    id:db.nextId++,
    nombre,
    edad:+document.getElementById('np-edad').value||0,
    sexo:document.getElementById('np-sexo').value,
    exp:document.getElementById('np-id').value||`EXP-${String(db.nextId-1).padStart(3,'0')}`,
    dx:document.getElementById('np-dx').value,
    med:document.getElementById('np-med').value,
    tel:document.getElementById('np-tel').value,
    color:colors[(db.nextId-2)%colors.length],
    pa:[],sueno:[]
  };
  db.patients.push(p);
  saveData();
  closeModal('modal-add');
  // reset
  ['np-nombre','np-edad','np-id','np-dx','np-med','np-tel'].forEach(id=>document.getElementById(id).value='');
  renderSidebar();
  selectPatient(p.id);
}

function savePA(){
  const sis=+document.getElementById('pa-sis').value;
  const dia=+document.getElementById('pa-dia').value;
  if(!sis||!dia||sis<70||sis>250||dia<40||dia>150){alert('Valores de presión arterial no válidos.');return;}
  const p=getPatient();
  if(!p){alert('Selecciona un paciente primero.');return;}
  p.pa.push({
    fecha:document.getElementById('pa-fecha').value||today(),
    hora:document.getElementById('pa-hora').value||nowTime(),
    sis,dia,
    pulso:+document.getElementById('pa-pulso').value||72,
    brazo:document.getElementById('pa-brazo').value,
    pos:document.getElementById('pa-pos').value,
    contexto:document.getElementById('pa-ctx').value,
    notas:document.getElementById('pa-notas').value,
  });
  p.pa.sort((a,b)=>a.fecha.localeCompare(b.fecha));
  saveData();
  closeModal('modal-pa');
  ['pa-sis','pa-dia','pa-pulso','pa-notas'].forEach(id=>document.getElementById(id).value='');
  renderSidebar();
  renderPatient();
}

function saveSueno(){
  const dormir=document.getElementById('su-dormir').value;
  const despertar=document.getElementById('su-despertar').value;
  if(!dormir||!despertar){alert('Ingresa hora de acostarse y despertar.');return;}
  const p=getPatient();
  if(!p){alert('Selecciona un paciente primero.');return;}
  p.sueno.push({
    fecha:document.getElementById('su-fecha').value||today(),
    dormir,despertar,
    cal:document.getElementById('su-cal').value,
    estres:+document.getElementById('su-estres').value,
    act:+document.getElementById('su-act').value,
    caf:+document.getElementById('su-caf').value,
    alc:+document.getElementById('su-alc').value,
    int:+document.getElementById('su-int').value||0,
    notas:document.getElementById('su-notas').value,
  });
  p.sueno.sort((a,b)=>a.fecha.localeCompare(b.fecha));
  saveData();
  closeModal('modal-sueno');
  document.getElementById('su-notas').value='';
  renderSidebar();
  renderPatient();
}

function updateField(id,field,val){
  const p=db.patients.find(p=>p.id===id);
  if(p){p[field]=val;saveData();renderSidebar();}
}

function deletePatient(id){
  if(!confirm('¿Eliminar este paciente y todos sus registros? Esta acción no se puede deshacer.'))return;
  db.patients=db.patients.filter(p=>p.id!==id);
  saveData();
  activePatientId=null;
  renderSidebar();
  renderOverview();
}

function exportCSV(id){
  const p=db.patients.find(p=>p.id===id);
  if(!p)return;
  let csv='Tipo,Fecha,Hora,Sistolica,Diastolica,Pulso,Contexto,Brazo,Notas\n';
  p.pa.forEach(r=>csv+=`PA,${r.fecha},${r.hora},${r.sis},${r.dia},${r.pulso},${r.contexto},${r.brazo},"${r.notas}"\n`);
  csv+='\nFecha,Dormir,Despertar,Horas,Calidad,Estres,Cafeina,Alcohol,Notas\n';
  p.sueno.forEach(r=>csv+=`${r.fecha},${r.dormir},${r.despertar},${calcH(r.dormir,r.despertar)},${r.cal},${r.estres},${r.caf},${r.alc},"${r.notas}"\n`);
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download=`${p.exp}_${p.nombre.replace(/ /g,'_')}.csv`;
  a.click();
}

