function barOpts(unit){
  return{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:i=>`${i.raw} ${unit}`}}},scales:{x:{ticks:{color:'#7d8590',font:{size:10}},grid:{display:false}},y:{ticks:{color:'#7d8590',font:{size:10}},grid:{color:'rgba(255,255,255,.04)'}}}};
}

