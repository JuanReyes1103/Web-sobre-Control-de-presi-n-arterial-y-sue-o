      <div class="card"><div class="card-label">Máxima sistólica</div><div class="card-val" style="color:var(--orange)">${max}</div><div class="card-unit">mmHg</div></div>
      <div class="card"><div class="card-label">Mínima sistólica</div><div class="card-val" style="color:var(--green)">${min}</div><div class="card-unit">mmHg</div></div>
      <div class="card"><div class="card-label">Total mediciones</div><div class="card-val" style="color:var(--blue)">${p.pa.length}</div></div>
    </div>
