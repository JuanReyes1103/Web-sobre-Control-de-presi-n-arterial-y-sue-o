function renderSidebar(q=''){
  const list=document.getElementById('patient-list');
  const search=q.toLowerCase();
  const filtered=db.patients.filter(p=>p.nombre.toLowerCase().includes(search)||p.exp.toLowerCase().includes(search));
  document.getElementById('count-label').textContent=db.patients.length;

  if(filtered.length===0){
    list.innerHTML=`<div class="no-data">Sin resultados</div>`;
    return;
  }

  list.innerHTML=filtered.map(p=>{
    const lastPA=p.pa.at(-1);
    const badgeHTML=lastPA
      ? `<span class="pa-badge ${clsPA(lastPA.sis,lastPA.dia).cls}">${lastPA.sis}/${lastPA.dia}</span>`
      : `<span class="pa-badge badge-gray">—</span>`;
    const isActive=p.id===activePatientId;
    return `<div class="patient-item${isActive?' active':''}" onclick="selectPatient(${p.id})">
      <div class="avatar" style="background:${p.color}22;color:${p.color}">${initials(p.nombre)}</div>
      <div class="patient-info">
        <div class="patient-name">${p.nombre}</div>
        <div class="patient-meta">${p.edad} años · ${p.exp}</div>
      </div>
      ${badgeHTML}
    </div>`;
  }).join('');
}

