<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EQUIPO 2 — Presión Arterial & Sueño</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{
  --bg:#0d1117;--s1:#161b22;--s2:#1f2733;--s3:#242e3a;
  --b1:rgba(255,255,255,.06);--b2:rgba(255,255,255,.11);--b3:rgba(255,255,255,.18);
  --tx:#e6edf3;--muted:#7d8590;--muted2:#adbac7;
  --red:#ff6b6b;--orange:#ffa94d;--green:#69db7c;--blue:#74c0fc;
  --purple:#c084fc;--teal:#34d399;--yellow:#fde68a;
  --r:10px;--r2:14px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;display:flex;flex-direction:column;}

/* ── Sidebar + main layout ── */
.app{display:flex;flex:1;overflow:hidden;height:100vh;}
.sidebar{width:260px;background:var(--s1);border-right:1px solid var(--b1);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column;}

/* ── Sidebar header ── */
.sidebar-head{padding:1.25rem 1rem .75rem;border-bottom:1px solid var(--b1);}
.brand{display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;}
.brand-pill{background:linear-gradient(135deg,#ff6b6b,#c084fc);color:#fff;font-size:.6rem;font-weight:700;letter-spacing:.08em;padding:.2rem .5rem;border-radius:4px;}
.brand h1{font-family:'DM Serif Display',serif;font-size:1rem;color:var(--tx);}
.brand h1 span{color:var(--red);}
.search-box{position:relative;}
.search-box input{width:100%;background:var(--s2);border:1px solid var(--b2);color:var(--tx);border-radius:var(--r);padding:.45rem .7rem .45rem 2rem;font-family:'DM Sans',sans-serif;font-size:.82rem;outline:none;transition:border-color .2s;}
.search-box input:focus{border-color:var(--blue);}
.search-box input::placeholder{color:var(--muted);}
.search-icon{position:absolute;left:.6rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.9rem;}

/* ── Patient list ── */
.sidebar-section-label{font-size:.65rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:.75rem 1rem .4rem;}
.patient-list{flex:1;overflow-y:auto;padding:0 .5rem .5rem;}
.patient-list::-webkit-scrollbar{width:4px;}
.patient-list::-webkit-scrollbar-track{background:transparent;}
.patient-list::-webkit-scrollbar-thumb{background:var(--b2);border-radius:4px;}
.patient-item{display:flex;align-items:center;gap:.6rem;padding:.5rem .6rem;border-radius:var(--r);cursor:pointer;transition:background .15s;margin-bottom:2px;position:relative;}
.patient-item:hover{background:var(--s2);}
.patient-item.active{background:var(--s3);border:1px solid var(--b2);}
.avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:600;flex-shrink:0;}
.patient-info{flex:1;min-width:0;}
.patient-name{font-size:.82rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.patient-meta{font-size:.7rem;color:var(--muted);}
.pa-badge{font-size:.6rem;font-weight:600;padding:.1rem .35rem;border-radius:3px;margin-left:auto;flex-shrink:0;}
.badge-ok{background:rgba(105,219,124,.15);color:#4ade80;border:1px solid rgba(105,219,124,.25);}
.badge-warn{background:rgba(255,169,77,.15);color:#fb923c;border:1px solid rgba(255,169,77,.25);}
.badge-danger{background:rgba(255,107,107,.15);color:#f87171;border:1px solid rgba(255,107,107,.25);}
.badge-gray{background:var(--b1);color:var(--muted);border:1px solid var(--b2);}

.btn-add-patient{display:flex;align-items:center;gap:.5rem;width:100%;padding:.55rem .8rem;background:transparent;border:1px dashed var(--b2);border-radius:var(--r);color:var(--muted);font-family:'DM Sans',sans-serif;font-size:.82rem;cursor:pointer;transition:all .2s;margin:.5rem 0;}
.btn-add-patient:hover{border-color:var(--blue);color:var(--blue);}

/* ── Top bar ── */
.topbar{background:var(--s1);border-bottom:1px solid var(--b1);padding:.85rem 1.75rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:sticky;top:0;z-index:50;}
.topbar-left h2{font-family:'DM Serif Display',serif;font-size:1.15rem;font-weight:400;}
.topbar-left p{font-size:.75rem;color:var(--muted);margin-top:.1rem;}
.topbar-right{display:flex;align-items:center;gap:.75rem;}
.clock{font-size:.78rem;color:var(--muted);text-align:right;line-height:1.5;}
.dot-live{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:glow 2s ease-in-out infinite;}
@keyframes glow{0%,100%{box-shadow:0 0 4px var(--green)}50%{box-shadow:0 0 12px var(--green)}}

/* ── Content area ── */
.content{padding:1.5rem 1.75rem;flex:1;}

/* ── Empty state ── */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:60vh;gap:1rem;text-align:center;}
.empty-state .icon{font-size:3rem;opacity:.4;}
.empty-state h3{font-family:'DM Serif Display',serif;font-size:1.3rem;color:var(--muted2);}
.empty-state p{font-size:.85rem;color:var(--muted);max-width:300px;line-height:1.6;}

/* ── Sub-tabs ── */
.sub-tabs{display:flex;gap:.35rem;background:var(--s1);border-radius:var(--r);padding:.3rem;border:1px solid var(--b1);margin-bottom:1.5rem;width:fit-content;}
.sub-tab{padding:.4rem .9rem;border:none;border-radius:7px;font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:500;cursor:pointer;background:transparent;color:var(--muted);transition:all .2s;}
.sub-tab.active{background:var(--s3);color:var(--tx);}
.sub-tab:hover:not(.active){color:var(--tx);}

/* ── Cards ── */
.cards-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:.85rem;margin-bottom:1.25rem;}
.card{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r2);padding:1.1rem 1.2rem;transition:border-color .2s;}
.card:hover{border-color:var(--b2);}
.card-label{font-size:.67rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:.5rem;}
.card-val{font-size:2rem;font-weight:300;font-family:'DM Serif Display',serif;line-height:1;}
.card-unit{font-size:.78rem;color:var(--muted);margin-top:.2rem;}
.card-sub{font-size:.72rem;color:var(--muted);margin-top:.45rem;}
.status-pill{display:inline-flex;align-items:center;gap:.3rem;font-size:.67rem;font-weight:600;padding:.2rem .55rem;border-radius:20px;margin-top:.45rem;}

/* ── Two col ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;}
@media(max-width:900px){.two-col{grid-template-columns:1fr;}.app{flex-direction:column;height:auto;}.sidebar{width:100%;height:auto;max-height:280px;}}

/* ── Chart card ── */
.chart-card{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r2);padding:1.25rem 1.4rem;margin-bottom:1rem;}
.chart-card h3{font-size:.7rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;}
.chart-wrap{position:relative;height:200px;}

/* ── Alert ── */
.alert{border-radius:var(--r);padding:.8rem 1rem;margin-bottom:.85rem;display:flex;gap:.65rem;font-size:.82rem;line-height:1.5;}
.alert-danger{background:rgba(255,107,107,.08);border:1px solid rgba(255,107,107,.2);color:#fca5a5;}
.alert-warn{background:rgba(255,169,77,.08);border:1px solid rgba(255,169,77,.2);color:#fdba74;}
.alert-info{background:rgba(116,192,252,.08);border:1px solid rgba(116,192,252,.2);color:#93c5fd;}
.alert-ok{background:rgba(105,219,124,.08);border:1px solid rgba(105,219,124,.2);color:#86efac;}

/* ── Form ── */
.form-card{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r2);padding:1.25rem 1.4rem;margin-bottom:1rem;}
.form-card h3{font-size:.7rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;}
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.85rem 1.2rem;}
.fg{display:flex;flex-direction:column;gap:.35rem;}
.fg label{font-size:.72rem;font-weight:500;color:var(--muted);}
.fg input,.fg select,.fg textarea{background:var(--bg);border:1px solid var(--b2);color:var(--tx);border-radius:var(--r);padding:.5rem .7rem;font-family:'DM Sans',sans-serif;font-size:.85rem;outline:none;transition:border-color .2s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--blue);}
.fg select option{background:var(--s2);}
.range-row{display:flex;align-items:center;gap:.6rem;margin-bottom:.6rem;}
.range-row label{font-size:.75rem;color:var(--muted);width:120px;flex-shrink:0;}
.range-row input[type=range]{flex:1;}
.range-val{font-size:.82rem;font-weight:500;min-width:28px;text-align:right;}
.btn-primary{background:linear-gradient(135deg,#ff6b6b,#c084fc);border:none;color:#fff;border-radius:var(--r);padding:.6rem 1.3rem;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;transition:opacity .2s,transform .1s;margin-top:.35rem;}
.btn-primary:hover{opacity:.88;}
.btn-primary:active{transform:scale(.98);}
.btn-sec{background:var(--s2);border:1px solid var(--b2);color:var(--tx);border-radius:var(--r);padding:.55rem 1rem;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:500;cursor:pointer;transition:background .2s;margin-top:.35rem;}
.btn-sec:hover{background:var(--s3);}
.btn-danger-sm{background:transparent;border:1px solid rgba(255,107,107,.3);color:#f87171;border-radius:var(--r);padding:.35rem .7rem;font-family:'DM Sans',sans-serif;font-size:.75rem;cursor:pointer;transition:all .2s;}
.btn-danger-sm:hover{background:rgba(255,107,107,.1);}

/* ── Table ── */
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:.8rem;}
th{font-size:.65rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);padding:.6rem .75rem;text-align:left;border-bottom:1px solid var(--b1);}
td{padding:.6rem .75rem;border-bottom:1px solid var(--b1);}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(255,255,255,.015);}

/* ── Modal overlay ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:200;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal{background:var(--s1);border:1px solid var(--b2);border-radius:var(--r2);padding:2rem;width:460px;max-width:95vw;max-height:90vh;overflow-y:auto;}
.modal h2{font-family:'DM Serif Display',serif;font-size:1.2rem;margin-bottom:1.25rem;}
.modal-footer{display:flex;gap:.5rem;justify-content:flex-end;margin-top:1.25rem;}

/* ── Stats overview ── */
.overview-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem;margin-bottom:1.5rem;}
.ov-card{background:var(--s2);border-radius:var(--r);padding:.85rem 1rem;text-align:center;}
.ov-num{font-size:1.7rem;font-weight:300;font-family:'DM Serif Display',serif;line-height:1;}
.ov-lbl{font-size:.65rem;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin-top:.25rem;}

/* ── Profile header ── */
.profile-header{display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;padding:.85rem 1.2rem;background:var(--s1);border:1px solid var(--b1);border-radius:var(--r2);}
.profile-avatar{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:600;flex-shrink:0;}
.profile-info h2{font-family:'DM Serif Display',serif;font-size:1.1rem;font-weight:400;}
.profile-info p{font-size:.75rem;color:var(--muted);margin-top:.15rem;}
.profile-actions{margin-left:auto;display:flex;gap:.5rem;}

/* ── General tab empty message ── */
.no-data{text-align:center;padding:2rem;color:var(--muted);font-size:.85rem;}

/* ── Scrollbar main ── */
.main::-webkit-scrollbar{width:5px;}
.main::-webkit-scrollbar-track{background:transparent;}
.main::-webkit-scrollbar-thumb{background:var(--b2);border-radius:4px;}
</style>
</head>
<body>
<div class="app">

<!-- ══════════════════════════════════════════
     SIDEBAR
══════════════════════════════════════════ -->
<aside class="sidebar">
  <div class="sidebar-head">
    <div class="brand">
      <span class="brand-pill">EQUIPO 2</span>
      <h1>PA <span>&</span> Sueño</h1>
    </div>
    <div class="search-box">
      <span class="search-icon">🔍</span>
      <input type="text" id="search-input" placeholder="Buscar paciente..." oninput="filterPatients(this.value)">
    </div>
  </div>

  <div class="sidebar-section-label">Pacientes (<span id="count-label">0</span>)</div>
  <div class="patient-list" id="patient-list"></div>

  <div style="padding:.5rem .75rem .75rem">
    <button class="btn-add-patient" onclick="openAddModal()">＋ Agregar paciente</button>
  </div>
</aside>

<!-- ══════════════════════════════════════════
     MAIN
══════════════════════════════════════════ -->
<div class="main">

  <!-- Top bar (overview mode) -->
  <div class="topbar" id="topbar-overview">
    <div class="topbar-left">
      <h2>Panel general</h2>
      <p>Monitoreo de presión arterial y sueño — todos los pacientes</p>
    </div>
    <div class="topbar-right">
      <div class="clock" id="clock"></div>
      <div class="dot-live"></div>
    </div>
  </div>

  <!-- Top bar (patient mode) -->
  <div class="topbar" id="topbar-patient" style="display:none">
    <div class="topbar-left">
      <h2 id="topbar-name">—</h2>
      <p id="topbar-meta">—</p>
    </div>
    <div class="topbar-right">
      <div class="clock" id="clock2"></div>
      <div class="dot-live"></div>
    </div>
  </div>

  <div class="content" id="main-content">
    <!-- rendered by JS -->
  </div>
</div>

</div><!-- /app -->

<!-- ══════════════════════════════════════════
     MODAL — AGREGAR PACIENTE
══════════════════════════════════════════ -->
<div class="modal-bg" id="modal-add" style="display:none" onclick="closeModalIfBg(event,'modal-add')">
  <div class="modal">
    <h2>Nuevo paciente</h2>
    <div class="form-grid">
      <div class="fg"><label>Nombre completo *</label><input id="np-nombre" type="text" placeholder="Ana García López"></div>
      <div class="fg"><label>Edad</label><input id="np-edad" type="number" min="1" max="120" placeholder="45"></div>
      <div class="fg"><label>Sexo</label><select id="np-sexo"><option value="F">Femenino</option><option value="M">Masculino</option><option value="O">Otro</option></select></div>
      <div class="fg"><label>ID / Expediente</label><input id="np-id" type="text" placeholder="EXP-001"></div>
      <div class="fg" style="grid-column:span 2"><label>Diagnósticos relevantes</label><input id="np-dx" type="text" placeholder="Hipertensión, Diabetes tipo 2..."></div>
      <div class="fg"><label>Medicación actual</label><input id="np-med" type="text" placeholder="Losartán 50mg..."></div>
      <div class="fg"><label>Teléfono/contacto</label><input id="np-tel" type="text" placeholder="+52 998 000 0000"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-sec" onclick="closeModal('modal-add')">Cancelar</button>
      <button class="btn-primary" onclick="addPatient()">Guardar paciente</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL — REGISTRAR PA
══════════════════════════════════════════ -->
<div class="modal-bg" id="modal-pa" style="display:none" onclick="closeModalIfBg(event,'modal-pa')">
  <div class="modal">
    <h2>Nueva medición de presión arterial</h2>
    <div class="form-grid">
      <div class="fg"><label>Sistólica (mmHg) *</label><input id="pa-sis" type="number" min="70" max="250" placeholder="120"></div>
      <div class="fg"><label>Diastólica (mmHg) *</label><input id="pa-dia" type="number" min="40" max="150" placeholder="80"></div>
      <div class="fg"><label>Pulso (lpm)</label><input id="pa-pulso" type="number" min="30" max="220" placeholder="72"></div>
      <div class="fg"><label>Brazo</label><select id="pa-brazo"><option value="izquierdo">Izquierdo</option><option value="derecho">Derecho</option></select></div>
      <div class="fg"><label>Posición</label><select id="pa-pos"><option value="sentado">Sentado</option><option value="acostado">Acostado</option><option value="de pie">De pie</option></select></div>
      <div class="fg"><label>Contexto</label><select id="pa-ctx"><option value="reposo">Reposo</option><option value="post-ejercicio">Post ejercicio</option><option value="post-comida">Post comida</option><option value="estrés">Estrés</option><option value="medicación">Con medicación</option></select></div>
      <div class="fg"><label>Fecha</label><input id="pa-fecha" type="date"></div>
      <div class="fg"><label>Hora</label><input id="pa-hora" type="time"></div>
      <div class="fg" style="grid-column:span 2"><label>Notas</label><input id="pa-notas" type="text" placeholder="Observaciones adicionales..."></div>
    </div>
    <div class="modal-footer">
      <button class="btn-sec" onclick="closeModal('modal-pa')">Cancelar</button>
      <button class="btn-primary" onclick="savePA()">Guardar medición</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL — REGISTRAR SUEÑO
══════════════════════════════════════════ -->
<div class="modal-bg" id="modal-sueno" style="display:none" onclick="closeModalIfBg(event,'modal-sueno')">
  <div class="modal">
    <h2>Nuevo registro de sueño</h2>
    <div class="form-grid">
      <div class="fg"><label>Fecha (noche)</label><input id="su-fecha" type="date"></div>
      <div class="fg"><label>Hora de acostarse</label><input id="su-dormir" type="time" value="22:30"></div>
      <div class="fg"><label>Hora de despertar</label><input id="su-despertar" type="time" value="06:30"></div>
      <div class="fg"><label>Calidad percibida</label>
        <select id="su-cal">
          <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
          <option value="4">⭐⭐⭐⭐ Bueno</option>
          <option value="3" selected>⭐⭐⭐ Regular</option>
          <option value="2">⭐⭐ Malo</option>
          <option value="1">⭐ Muy malo</option>
        </select>
      </div>
      <div class="fg"><label>Interrupciones</label><input id="su-int" type="number" min="0" max="20" placeholder="0"></div>
    </div>
    <div style="margin-top:1rem">
      <p style="font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.6rem;">Factores</p>
      <div class="range-row"><label>Estrés del día</label><input type="range" id="su-estres" min="1" max="10" value="5" oninput="rv('su-estres','rv-estres')"><span class="range-val" id="rv-estres">5</span></div>
      <div class="range-row"><label>Actividad física</label><input type="range" id="su-act" min="1" max="10" value="4" oninput="rv('su-act','rv-act')"><span class="range-val" id="rv-act">4</span></div>
      <div class="range-row"><label>Cafeína (tazas)</label><input type="range" id="su-caf" min="0" max="10" value="2" oninput="rv('su-caf','rv-caf')"><span class="range-val" id="rv-caf">2</span></div>
      <div class="range-row"><label>Alcohol (copas)</label><input type="range" id="su-alc" min="0" max="10" value="0" oninput="rv('su-alc','rv-alc')"><span class="range-val" id="rv-alc">0</span></div>
    </div>
    <div class="fg" style="margin-top:.5rem"><label>Notas</label><input id="su-notas" type="text" placeholder="Pesadillas, ronquidos, temperatura..."></div>
    <div class="modal-footer">
      <button class="btn-sec" onclick="closeModal('modal-sueno')">Cancelar</button>
      <button class="btn-primary" onclick="saveSueno()">Guardar sueño</button>
    </div>
  </div>
</div>

<script>
// ════════════════════════════════════════════════════════
//  DATA STORE (localStorage para persistencia)
// ════════════════════════════════════════════════════════
const STORE_KEY = 'eq2_data_v2';

function loadData(){
  try{ return JSON.parse(localStorage.getItem(STORE_KEY)) || {patients:[],nextId:1}; }
  catch{ return {patients:[],nextId:1}; }
}
function saveData(){
  localStorage.setItem(STORE_KEY, JSON.stringify(db));
}

let db = loadData();

// Seed demo si está vacío
if(db.patients.length === 0){
  const seedPats = [
    {id:1,nombre:'Ana García López',edad:52,sexo:'F',exp:'EXP-001',dx:'Hipertensión esencial',med:'Losartán 50mg',tel:'998-100-0001',color:'#c084fc'},
    {id:2,nombre:'Roberto Mendez',edad:67,sexo:'M',exp:'EXP-002',dx:'Hipertensión grado 2, DM2',med:'Amlodipino 5mg, Metformina',tel:'998-100-0002',color:'#74c0fc'},
    {id:3,nombre:'María Torres',edad:38,sexo:'F',exp:'EXP-003',dx:'Sin diagnóstico previo',med:'Ninguna',tel:'998-100-0003',color:'#34d399'},
    {id:4,nombre:'Carlos Ruiz Díaz',edad:45,sexo:'M',exp:'EXP-004',dx:'Estrés laboral crónico',med:'Ninguna',tel:'998-100-0004',color:'#ffa94d'},
  ];
  const daysAgo = (n)=>{
    const d = new Date(); d.setDate(d.getDate()-n);
    return d.toISOString().slice(0,10);
  };
  seedPats.forEach(p=>{
    p.pa=[];p.sueno=[];
    const baseSis=[p.id===2?148:p.id===1?135:p.id===4?128:115];
    for(let i=6;i>=0;i--){
      const s = baseSis[0]+Math.round((Math.random()-.3)*12);
      const d = Math.round(s*.62+Math.random()*8);
      p.pa.push({fecha:daysAgo(i),hora:'07:'+String(10+Math.floor(Math.random()*40)).padStart(2,'0'),
        sis:s,dia:d,pulso:65+Math.round(Math.random()*20),
        contexto:'reposo',brazo:'izquierdo',notas:''});
      const dormin = 22+Math.round(Math.random()*2);
      const dormH  = `${dormin%24}:${Math.random()>.5?'30':'00'}`;
      const wakeH  = `0${5+Math.round(Math.random()*2)}:${Math.random()>.5?'30':'00'}`;
      p.sueno.push({fecha:daysAgo(i),dormir:dormH,despertar:wakeH,
        cal:String(2+Math.round(Math.random()*3)),
        estres:2+Math.round(Math.random()*7),act:2+Math.round(Math.random()*7),
        caf:Math.round(Math.random()*4),alc:0,int:Math.round(Math.random()*3),notas:''});
    }
  });
  db = {patients:seedPats, nextId:5};
  saveData();
}

