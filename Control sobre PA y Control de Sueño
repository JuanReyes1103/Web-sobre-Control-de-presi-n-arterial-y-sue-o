function renderTabPA(p){
  if(!p.pa.length)return`<div class="no-data">Este paciente aún no tiene mediciones de presión arterial.<br><button class="btn-primary" style="margin-top:.75rem" onclick="openModalPA()">➕ Agregar primera medición</button></div>`;
  const rows=[...p.pa].reverse().map(r=>{
    const c=clsPA(r.sis,r.dia);
    return`<tr><td>${r.fecha} ${r.hora}</td><td><strong>${r.sis}</strong></td><td><strong>${r.dia}</strong></td><td>${r.pulso}</td><td>${r.contexto}</td><td>${r.brazo}</td><td><span class="status-pill ${c.cls}">${c.emoji} ${c.label}</span></td><td style="color:var(--muted);font-size:.75rem">${r.notas}</td></tr>`;
