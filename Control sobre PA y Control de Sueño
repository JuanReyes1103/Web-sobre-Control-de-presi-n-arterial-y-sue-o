function renderTabSueno(p){
  if(!p.sueno.length)return`<div class="no-data">Este paciente aún no tiene registros de sueño.<br><button class="btn-primary" style="margin-top:.75rem;background:linear-gradient(135deg,#7c3aed,#c084fc)" onclick="openModalSueno()">🌙 Agregar primer registro</button></div>`;
  const avgH=Math.round(p.sueno.reduce((a,r)=>a+calcH(r.dormir,r.despertar),0)/p.sueno.length*10)/10;
  const avgCal=Math.round(p.sueno.reduce((a,r)=>a+(+r.cal),0)/p.sueno.length*10)/10;
  const avgEst=Math.round(p.sueno.reduce((a,r)=>a+r.estres,0)/p.sueno.length*10)/10;
  const rows=[...p.sueno].reverse().map(r=>{
    const h=calcH(r.dormir,r.despertar);
    const c=clsH(h);
    return`<tr><td>${r.fecha}</td><td><span class="status-pill ${c.cls}">${h}h</span></td><td>${r.dormir}</td><td>${r.despertar}</td><td>${stars(r.cal)}</td><td>${r.estres}/10</td><td>${r.caf} ☕</td><td style="color:var(--muted);font-size:.75rem">${r.notas}</td></tr>`;
  }).join('');
  return`
    <div class="cards-row">
      <div class="card"><div class="card-label">Promedio horas</div><div class="card-val" style="color:var(--purple)">${avgH}</div><div class="card-unit">horas/noche</div></div>
      <div class="card"><div class="card-label">Calidad promedio</div><div class="card-val" style="color:var(--yellow)">${avgCal}</div><div class="card-unit">/ 5</div></div>
      <div class="card"><div class="card-label">Estrés promedio</div><div class="card-val" style="color:var(--orange)">${avgEst}</div><div class="card-unit">/ 10</div></div>
      <div class="card"><div class="card-label">Total registros</div><div class="card-val" style="color:var(--teal)">${p.sueno.length}</div></div>
    </div>
    <div class="chart-card"><h3>Horas de sueño por noche</h3><div class="chart-wrap" style="height:200px"><canvas id="ch-su-full"></canvas></div></div>
    <div class="chart-card"><h3>Historial de sueño</h3>
      <div style="text-align:right;margin-bottom:.6rem"><button class="btn-sec" style="font-size:.75rem;padding:.35rem .7rem" onclick="openModalSueno()">🌙 Nueva noche</button></div>
      <div class="table-wrap"><table><thead><tr><th>Fecha</th><th>Duración</th><th>Acostarse</th><th>Despertar</th><th>Calidad</th><th>Estrés</th><th>Cafeína</th><th>Notas</th></tr></thead><tbody>${rows}</tbody></table></div>
    </div>`;
}

function renderTabCorr(p){
  const n=Math.min(p.pa.length,p.sueno.length);
  if(n<2)return`<div class="no-data">Se necesitan al menos 2 registros de PA y sueño para mostrar correlación.</div>`;
  return`
    <div class="alert alert-info">ℹ️ <div>El sueño insuficiente (&lt;6h) puede elevar la presión sistólica 5–15 mmHg. Revisa si existe patrón en este paciente.</div></div>
    <div class="two-col">
      <div class="chart-card"><h3>Sueño vs. Sistólica</h3><div class="chart-wrap"><canvas id="ch-corr1"></canvas></div></div>
      <div class="chart-card"><h3>Estrés vs. Sistólica</h3><div class="chart-wrap"><canvas id="ch-corr2"></canvas></div></div>
    </div>
    <div class="chart-card"><h3>Tendencia combinada (sueño + PA)</h3><div class="chart-wrap" style="height:240px"><canvas id="ch-dual"></canvas></div></div>
  `;
}

// ════════════════════════════════════════════════════════
//  CHARTS DEL PACIENTE
// ════════════════════════════════════════════════════════
function drawPatientCharts(p){
  const labels7=p.pa.slice(-7).map(r=>r.fecha.slice(5));
  const sis7=p.pa.slice(-7).map(r=>r.sis);
  const dia7=p.pa.slice(-7).map(r=>r.dia);
  const su7=p.sueno.slice(-7);

  const lineOpts=(yl,yr)=>({
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{labels:{color:'#7d8590',font:{size:10},boxWidth:10}}},
    scales:{
      x:{ticks:{color:'#7d8590',font:{size:9}},grid:{color:'rgba(255,255,255,.03)'}},
      [yl||'y']:{ticks:{color:'#7d8590',font:{size:9}},grid:{color:'rgba(255,255,255,.03)'}},
      ...(yr?{[yr]:{position:'right',ticks:{color:'#7d8590',font:{size:9}},grid:{display:false}}}:{}),
    },
    interaction:{intersect:false,mode:'index'}
  });

  // Resumen PA mini
  const c1=document.getElementById('ch-pa')?.getContext('2d');
  if(c1&&p.pa.length>0){
    chartInstances['ch-pa']=new Chart(c1,{type:'line',data:{labels:labels7,datasets:[
      {label:'Sistólica',data:sis7,borderColor:'#ff6b6b',backgroundColor:'rgba(255,107,107,.1)',fill:true,tension:.4,pointRadius:3,pointBackgroundColor:'#ff6b6b'},
      {label:'Diastólica',data:dia7,borderColor:'#74c0fc',backgroundColor:'rgba(116,192,252,.05)',fill:false,tension:.4,pointRadius:3,pointBackgroundColor:'#74c0fc'},
    ]},options:lineOpts()});
  }

  // Resumen sueño mini
  const c2=document.getElementById('ch-su')?.getContext('2d');
  if(c2&&su7.length>0){
    const horas=su7.map(r=>calcH(r.dormir,r.despertar));
    chartInstances['ch-su']=new Chart(c2,{type:'bar',data:{labels:su7.map(r=>r.fecha.slice(5)),datasets:[{data:horas,backgroundColor:horas.map(h=>h>=7?'#c084fc':h>=6?'#ffa94d':'#ff6b6b'),borderRadius:5,borderSkipped:false}]},options:{...lineOpts(),plugins:{legend:{display:false}}}});
  }

  // Tab PA full
  const c3=document.getElementById('ch-pa-full')?.getContext('2d');
  if(c3&&p.pa.length>0){
    chartInstances['ch-pa-f']=new Chart(c3,{type:'line',data:{labels:p.pa.map(r=>r.fecha.slice(5)),datasets:[
      {label:'Sistólica',data:p.pa.map(r=>r.sis),borderColor:'#ff6b6b',backgroundColor:'rgba(255,107,107,.08)',fill:true,tension:.4,pointRadius:4,pointBackgroundColor:'#ff6b6b'},
      {label:'Diastólica',data:p.pa.map(r=>r.dia),borderColor:'#74c0fc',fill:false,tension:.4,pointRadius:4,pointBackgroundColor:'#74c0fc'},
      {label:'Pulso',data:p.pa.map(r=>r.pulso),borderColor:'#34d399',fill:false,tension:.4,pointRadius:3,pointBackgroundColor:'#34d399',borderDash:[4,3]},
    ]},options:lineOpts()});
  }

  // Tab sueño full
  const c4=document.getElementById('ch-su-full')?.getContext('2d');
  if(c4&&p.sueno.length>0){
    const hs=p.sueno.map(r=>calcH(r.dormir,r.despertar));
    chartInstances['ch-su-f']=new Chart(c4,{type:'bar',data:{labels:p.sueno.map(r=>r.fecha.slice(5)),datasets:[{data:hs,backgroundColor:hs.map(h=>h>=7?'#c084fc':h>=6?'#ffa94d':'#ff6b6b'),borderRadius:5,borderSkipped:false}]},options:{...lineOpts(),plugins:{legend:{display:false}}}});
  }

  // Correlaciones
  const n=Math.min(p.pa.length,p.sueno.length);
  if(n>=2){
    const corrData=Array.from({length:n},(_,i)=>({x:calcH(p.sueno[i].dormir,p.sueno[i].despertar),y:p.pa[i].sis}));
    const corrData2=Array.from({length:n},(_,i)=>({x:p.sueno[i].estres,y:p.pa[i].sis}));
    const scatterOpts=(xl,yl)=>({responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{title:{display:true,text:xl,color:'#7d8590',font:{size:10}},ticks:{color:'#7d8590'},grid:{color:'rgba(255,255,255,.03)'}},y:{title:{display:true,text:yl,color:'#7d8590',font:{size:10}},ticks:{color:'#7d8590'},grid:{color:'rgba(255,255,255,.03)'}}}});

    const c5=document.getElementById('ch-corr1')?.getContext('2d');
    if(c5) chartInstances['corr1']=new Chart(c5,{type:'scatter',data:{datasets:[{data:corrData,backgroundColor:'#c084fc',pointRadius:6}]},options:scatterOpts('Horas sueño','Sistólica mmHg')});

    const c6=document.getElementById('ch-corr2')?.getContext('2d');
    if(c6) chartInstances['corr2']=new Chart(c6,{type:'scatter',data:{datasets:[{data:corrData2,backgroundColor:'#ff6b6b',pointRadius:6}]},options:scatterOpts('Estrés (1–10)','Sistólica mmHg')});

    const c7=document.getElementById('ch-dual')?.getContext('2d');
    if(c7){
      const dualLabels=p.pa.slice(-n).map(r=>r.fecha.slice(5));
      const dualH=p.sueno.slice(-n).map(r=>calcH(r.dormir,r.despertar));
      const dualSis=p.pa.slice(-n).map(r=>r.sis);
      chartInstances['dual']=new Chart(c7,{type:'line',data:{labels:dualLabels,datasets:[
        {label:'Sueño (h)',data:dualH,borderColor:'#c084fc',backgroundColor:'rgba(192,132,252,.08)',fill:true,tension:.4,pointRadius:4,yAxisID:'yS'},
        {label:'Sistólica',data:dualSis,borderColor:'#ff6b6b',fill:false,tension:.4,pointRadius:4,yAxisID:'yPA'},
      ]},options:{responsive:true,maintainAspectRatio:false,interaction:{intersect:false,mode:'index'},plugins:{legend:{labels:{color:'#7d8590',font:{size:10}}}},scales:{x:{ticks:{color:'#7d8590',font:{size:9}},grid:{color:'rgba(255,255,255,.03)'}},yS:{position:'left',title:{display:true,text:'Horas sueño',color:'#c084fc',font:{size:9}},ticks:{color:'#c084fc'},grid:{display:false}},yPA:{position:'right',title:{display:true,text:'Sistólica mmHg',color:'#ff6b6b',font:{size:9}},ticks:{color:'#ff6b6b'},grid:{color:'rgba(255,255,255,.03)'}}}}});
    }
  }
}

