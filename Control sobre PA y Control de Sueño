      </div></td>
      <td>${p.edad} · ${p.sexo}</td>
      <td>${lPA?`<strong>${lPA.sis}/${lPA.dia}</strong>`:'—'}</td>
      <td>${lPA?lPA.pulso:'—'}</td>
      <td>${lPA?`<span class="status-pill ${c.cls}">${c.emoji} ${c.label}</span>`:'<span class="status-pill badge-gray">Sin datos</span>'}</td>
      <td>${h?`${h}h`:'—'}</td>
      <td>${lS?stars(lS.cal):'—'}</td>
      <td>${h?`<span class="status-pill ${cs.cls}">${cs.label}</span>`:'<span class="status-pill badge-gray">Sin datos</span>'}</td>
      <td><span style="font-size:.72rem;color:var(--muted)">${lPA?lPA.fecha:'—'}</span></td>
    </tr>`;
  }).join('');

  document.getElementById('main-content').innerHTML=`
    ${alertsHtml}
    <div class="overview-grid">
      <div class="ov-card"><div class="ov-num">${total}</div><div class="ov-lbl">Pacientes</div></div>
      <div class="ov-card"><div class="ov-num" style="color:var(--green)">${conPA.length}</div><div class="ov-lbl">Con medición PA</div></div>
      <div class="ov-card"><div class="ov-num" style="color:var(--purple)">${conSueno.length}</div><div class="ov-lbl">Con registro sueño</div></div>
      <div class="ov-card"><div class="ov-num" style="color:var(--red)">${enCrisis.length}</div><div class="ov-lbl">En alerta crítica</div></div>
      <div class="ov-card"><div class="ov-num" style="color:var(--orange)">${enAlerta.length-enCrisis.length}</div><div class="ov-lbl">Presión elevada</div></div>
    </div>

    <div class="chart-card">
      <h3>Todos los pacientes — resumen</h3>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Paciente</th><th>Edad/Sexo</th><th>PA (mmHg)</th><th>Pulso</th><th>Estado PA</th><th>Sueño</th><th>Calidad</th><th>Estado sueño</th><th>Última medición</th></tr></thead>
          <tbody>${rows||'<tr><td colspan="9" class="no-data">Agrega pacientes para comenzar</td></tr>'}</tbody>
        </table>
      </div>
    </div>

    <div class="two-col">
      <div class="chart-card">
        <h3>Distribución PA sistólica</h3>
        <div class="chart-wrap"><canvas id="ov-chart-pa"></canvas></div>
      </div>
