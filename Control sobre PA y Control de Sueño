        <h3>Sueño promedio por paciente</h3>
        <div class="chart-wrap"><canvas id="ov-chart-sueno"></canvas></div>
      </div>
    </div>
  `;

  // Charts overview
  const names=db.patients.map(p=>p.nombre.split(' ')[0]);
  const sisCurrent=db.patients.map(p=>p.pa.at(-1)?.sis||0);
  const colorsPA=sisCurrent.map(s=>s>=140?'#ff6b6b':s>=130?'#ffa94d':s>=120?'#fde68a':'#69db7c');
  const avgSueno=db.patients.map(p=>{
    if(!p.sueno.length)return 0;
    return Math.round(p.sueno.reduce((a,r)=>a+calcH(r.dormir,r.despertar),0)/p.sueno.length*10)/10;
  });
  const colorsSueno=avgSueno.map(h=>h>=7?'#c084fc':h>=6?'#ffa94d':'#ff6b6b');

  setTimeout(()=>{
