function tick(){
  const n=new Date();
  const s=n.toLocaleDateString('es-MX',{weekday:'short',day:'numeric',month:'short'})+'\n'+n.toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'});
  ['clock','clock2'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=s.replace('\n','<br>');});
}
tick();setInterval(tick,1000);

