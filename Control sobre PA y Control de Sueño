// ════════════════════════════════════════════════════════
function calcH(dormir,despertar){
  const [dh,dm]=dormir.split(':').map(Number);
  const [wh,wm]=despertar.split(':').map(Number);
  let m=(wh*60+wm)-(dh*60+dm);
  if(m<0)m+=1440;
  return Math.round(m/6)/10;
}
function clsPA(s,d){
  if(s>180||d>120)return{label:'Crisis',cls:'badge-danger',emoji:'🚨'};
  if(s>=140||d>=90) return{label:'HTA G2',cls:'badge-danger',emoji:'🚨'};
  if(s>=130||d>=80) return{label:'HTA G1',cls:'badge-warn',emoji:'⚠'};
  if(s>=120)         return{label:'Elevada',cls:'badge-warn',emoji:'⚠'};
  return{label:'Normal',cls:'badge-ok',emoji:'✓'};
}
function clsH(h){
  if(h>=7)return{label:'Óptimo',cls:'badge-ok'};
  if(h>=6)return{label:'Insuf.',cls:'badge-warn'};
  return{label:'Defic.',cls:'badge-danger'};
}
function initials(name){return name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();}
function today(){return new Date().toISOString().slice(0,10);}
function nowTime(){return new Date().toTimeString().slice(0,5);}
function stars(n){return '⭐'.repeat(+n);}
function destroyCharts(){Object.values(chartInstances).forEach(c=>{try{c.destroy()}catch{}});chartInstances={};}
function rv(id,vid){document.getElementById(vid).textContent=document.getElementById(id).value;}

