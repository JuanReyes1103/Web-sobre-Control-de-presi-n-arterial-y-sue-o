  const enCrisis=conPA.filter(p=>{const l=p.pa.at(-1);return l&&(l.sis>=140||l.dia>=90);});

  let alertsHtml='';
  if(enCrisis.length>0){
    alertsHtml+=`<div class="alert alert-danger">🚨 <div><strong>${enCrisis.length} paciente(s) con hipertensión grado 2 o superior:</strong> ${enCrisis.map(p=>p.nombre).join(', ')}. Se recomienda atención prioritaria.</div></div>`;
